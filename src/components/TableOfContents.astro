---
// Client-side table of contents. Scans #article for h2-h4 headings,
// generates links, and enables smooth scrolling.
const tocTitle = "目录";
const copyLinkLabel = "复制链接";
---

<nav id="toc" class="prose-sm" data-copy-link-label={copyLinkLabel}>
  <h2 class="mb-2 text-base font-semibold uppercase tracking-wide text-foreground">{tocTitle}</h2>
  <ul class="space-y-1 max-h-[calc(100vh-8rem)] overflow-y-auto"></ul>
</nav>

<script>
  function slugify(s: string): string {
    return s
      .toString()
      .trim()
      .toLowerCase()
      .replace(/[^\w\-\s]/g, "")
      .replace(/\s+/g, "-");
  }

  function addHeadingLinks(copyLinkLabel: string) {
    const headings = document.querySelectorAll(
      "#article h2, #article h3, #article h4, #article h5, #article h6"
    );
    headings.forEach((heading) => {
      if (heading.querySelector(".heading-link")) return;
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      const el = heading as HTMLElement;
      if (!el.id || el.id.trim() === "") {
        el.id = slugify(el.innerText || el.textContent || "");
      }
      link.href = "#" + el.id;
      link.setAttribute("aria-label", copyLinkLabel);
      heading.appendChild(link);
    });
  }

  function initTOC() {
    const container = document.getElementById("toc");
    if (!container) return;

    const list = container.querySelector("ul");
    if (!list) return;

    list.innerHTML = "";

    const article = document.getElementById("article");
    if (!article) {
      container.style.display = "none";
      return;
    }

    const copyLinkLabel = container.dataset.copyLinkLabel ?? "Copy link";
    addHeadingLinks(copyLinkLabel);

    const headingEls = article.querySelectorAll("h2, h3, h4");
    const headings: { id: string; text: string; level: number }[] = [];

    headingEls.forEach((h) => {
      const el = h as HTMLElement;
      if (!el.id || el.id.trim() === "") {
        el.id = slugify(el.innerText || el.textContent || "");
      }
      headings.push({
        id: el.id,
        text: el.innerText || el.textContent || "",
        level: parseInt(el.tagName.replace("H", "")),
      });
    });

    if (!headings.length) {
      container.style.display = "none";
      return;
    }

    container.style.display = "";

    headings.forEach(({ id, text, level }) => {
      const li = document.createElement("li");
      li.style.paddingLeft = `${Math.max(0, (level - 2) * 12)}px`;
      const a = document.createElement("a");
      a.href = `#${id}`;
      a.textContent = text;
      a.className =
        "text-sm hover:underline block text-foreground/80 transition-colors py-0.5";
      li.appendChild(a);
      list.appendChild(li);
    });

    const tocLinks = Array.from(list.querySelectorAll("a"));
    const headingElements = headings
      .map((h) => document.getElementById(h.id))
      .filter(Boolean);

    function onScroll() {
      let currentIndex = -1;
      for (let i = 0; i < headingElements.length; i++) {
        const el = headingElements[i];
        if (!el) continue;
        const rect = el.getBoundingClientRect();
        if (rect.top <= 100) currentIndex = i;
      }
      tocLinks.forEach((link, idx) => {
        const isActive = idx === currentIndex;
        link.classList.toggle("text-accent", isActive);
        link.classList.toggle("font-semibold", isActive);
        link.classList.toggle("text-foreground/80", !isActive);
      });
    }

    list.addEventListener("click", (e) => {
      const a = (e.target as HTMLElement).closest("a");
      if (!a) return;
      e.preventDefault();
      const id = a.getAttribute("href")?.slice(1);
      if (!id) return;
      const target = document.getElementById(id);
      if (!target) return;
      const y = target.getBoundingClientRect().top + window.scrollY - 80;
      window.scrollTo({ top: y, behavior: "smooth" });
      history.replaceState(history.state, "", "#" + id);
    });

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  // Run on initial load
  initTOC();

  // Re-run on Astro page transitions
  document.addEventListener("astro:after-swap", initTOC);
</script>

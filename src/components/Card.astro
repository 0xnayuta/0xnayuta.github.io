---
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import { slugifyStr } from "@/utils/slugify";
import Datetime from "./Datetime.astro";
import TruncateText from "./TruncateText.astro";
import { extractExcerpt } from "@/utils/extractExcerpt";

type Props = {
  variant?: "h2" | "h3";
  maxLines?: number;
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath, body, maxLines = 2 } =
  Astro.props;

const { title, description, ...props } = data;
const excerpt = description || extractExcerpt(body || "", 200);
---

<li class="my-6">
  <a
    href={getPostUrl(id, filePath, Astro.currentLocale)}
    class:list={[
      "text-accent inline-block text-lg font-medium",
      "decoration-dashed underline-offset-4 hover:underline",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <Heading transition:name={slugifyStr(title.replaceAll(".", "-"))}>
      {title}
    </Heading>
  </a>
  <Datetime class="mt-2" {...props} />
  <TruncateText
    text={excerpt}
    maxLines={maxLines}
    class="mt-3 text-foreground/80"
  />
</li>

---
interface Props {
  defaultQuote: string;
  defaultSource: string;
}

const { defaultQuote, defaultSource } = Astro.props;
---

<p
  class="hitokoto hitokoto-pending w-full"
  role="status"
  aria-live="polite"
  data-hitokoto
  data-default-quote={defaultQuote}
  data-default-source={defaultSource}
>
  <span class="hitokoto-text block w-full text-base font-semibold">
    <span class="hitokoto-quote text-2xl align-top me-2">"</span>
    <span class="hitokoto-inner">{defaultQuote}</span>
    <span class="hitokoto-quote text-2xl align-top ms-2">"</span>
  </span>
  <span class="hitokoto-from mt-3 block w-full text-end text-sm"> —— {defaultSource}</span>
</p>
<noscript>
  <style>
    [data-hitokoto] {
      visibility: visible !important;
    }
  </style>
</noscript>

<script>
  type HitokotoItem = {
    sentence: string;
    source: string;
  };

  const CACHE_KEY = "hitokoto_cache";
  const CACHE_TIME_KEY = "hitokoto_cache_time";
  const CACHE_DURATION = 10 * 60 * 1000;
  const HITOKOTO_API = "https://v1.hitokoto.cn/?c=a&c=b&c=d&c=i&c=k";

  function getFallback(container: HTMLElement): HitokotoItem {
    return {
      sentence: container.dataset.defaultQuote ?? "",
      source: container.dataset.defaultSource ?? "",
    };
  }

  function getDisplayed(container: HTMLElement): HitokotoItem {
    return {
      sentence:
        container.dataset.currentSentence ??
        container.querySelector(".hitokoto-inner")?.textContent?.trim() ??
        "",
      source: container.dataset.currentSource ?? "",
    };
  }

  function isSameHitokoto(a: HitokotoItem, b: HitokotoItem): boolean {
    return a.sentence === b.sentence && a.source === b.source;
  }

  function loadFromCache(): HitokotoItem | null {
    try {
      const cached = localStorage.getItem(CACHE_KEY);
      const cachedTime = localStorage.getItem(CACHE_TIME_KEY);
      if (!cached || !cachedTime) return null;

      const timestamp = Number(cachedTime);
      if (!Number.isFinite(timestamp)) return null;

      const age = Date.now() - timestamp;
      if (age >= CACHE_DURATION) return null;

      const parsed = JSON.parse(cached);
      if (!parsed?.sentence) return null;

      return {
        sentence: String(parsed.sentence),
        source: parsed.source ? String(parsed.source) : "",
      };
    } catch {
      return null;
    }
  }

  function saveToCache(item: HitokotoItem) {
    try {
      localStorage.setItem(
        CACHE_KEY,
        JSON.stringify({ sentence: item.sentence, source: item.source })
      );
      localStorage.setItem(CACHE_TIME_KEY, String(Date.now()));
    } catch {
      // ignore
    }
  }

  function animate(el: HTMLElement | null) {
    if (!el) return;
    el.classList.remove("fade-in");
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        el.classList.add("fade-in");
        el.addEventListener(
          "animationend",
          () => {
            el.classList.remove("fade-in");
          },
          { once: true }
        );
      });
    });
  }

  function renderHitokoto(
    container: HTMLElement,
    item: HitokotoItem,
    options: { animate?: boolean } = {}
  ) {
    const textWrapper = container.querySelector(".hitokoto-text") as HTMLElement | null;
    const innerEl = container.querySelector(".hitokoto-inner") as HTMLElement | null;
    const fromEl = container.querySelector(".hitokoto-from") as HTMLElement | null;

    if (innerEl) {
      innerEl.textContent = item.sentence;
    }
    if (fromEl) {
      fromEl.textContent = item.source ? ` —— ${item.source}` : "";
    }

    container.dataset.currentSentence = item.sentence;
    container.dataset.currentSource = item.source;
    container.classList.remove("hitokoto-pending");

    if (options.animate) {
      animate(textWrapper);
      animate(fromEl);
    }
  }

  async function fetchHitokoto(signal: AbortSignal): Promise<HitokotoItem | null> {
    const res = await fetch(HITOKOTO_API, { signal });
    if (!res.ok) throw new Error("Network response failed");

    const data = await res.json();
    const sentence = data.hitokoto || data.sentence || "";
    if (!sentence) return null;

    return {
      sentence,
      source: data.from_who || data.from || "",
    };
  }

  async function initHitokoto(container: HTMLElement) {
    if (container.dataset.hitokotoLoading === "true") return;
    container.dataset.hitokotoLoading = "true";

    const requestId = String((Number(container.dataset.hitokotoReqId || "0") || 0) + 1);
    container.dataset.hitokotoReqId = requestId;

    const initial = loadFromCache() || getFallback(container);
    renderHitokoto(container, initial, { animate: false });

    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 5000);

    try {
      const fresh = await fetchHitokoto(controller.signal);
      if (!fresh) return;
      if (container.dataset.hitokotoReqId !== requestId) return;

      if (!isSameHitokoto(getDisplayed(container), fresh)) {
        renderHitokoto(container, fresh, { animate: true });
      }

      saveToCache(fresh);
    } catch {
      // keep current content (cached or fallback)
    } finally {
      clearTimeout(timeout);
      if (container.dataset.hitokotoReqId === requestId) {
        container.dataset.hitokotoLoading = "false";
      }
    }
  }

  function initHitokotos() {
    document
      .querySelectorAll<HTMLElement>("[data-hitokoto]")
      .forEach(container => {
        void initHitokoto(container);
      });
  }

  const win = window as Window & { __hitokotoPageLoadListener?: boolean };
  initHitokotos();
  if (!win.__hitokotoPageLoadListener) {
    win.__hitokotoPageLoadListener = true;
    document.addEventListener("astro:page-load", initHitokotos);
  }
</script>

<style>
  .hitokoto {
    margin-top: 0.75rem;
    line-height: 1.8;
  }

  .hitokoto.hitokoto-pending {
    visibility: hidden;
    animation: hitokoto-safe-reveal 0s linear 1s forwards;
  }

  .hitokoto .hitokoto-text {
    font-style: italic;
    font-weight: 600;
    opacity: 1;
  }

  .hitokoto .hitokoto-from {
    font-size: 0.875rem;
    font-weight: 500;
    opacity: 1;
  }

  .fade-in {
    animation: hitokoto-fade-in 0.45s ease forwards;
  }

  @keyframes hitokoto-fade-in {
    from {
      opacity: 0;
      transform: translateY(2px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hitokoto-safe-reveal {
    to {
      visibility: visible;
    }
  }
</style>

---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import Hr from "@/components/Hr.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <section id="hero" class="pt-8 pb-6">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Ciallo~(∠・ω&lt; )⌒★
      </h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

  <p id="hitokoto" class="hitokoto w-full" role="status" aria-live="polite">
        <span class="hitokoto-text block w-full text-base">
          <span class="hitokoto-quote text-2xl align-top mr-2">"</span>
          <span class="hitokoto-inner">世界上只有一种真正的英雄主义,那就是在认清生活的真相之后,依然热爱生活。</span>
          <span class="hitokoto-quote text-2xl align-top ml-2">"</span>
        </span>
        <span class="hitokoto-from block w-full text-end mt-3"> -- 罗曼·罗兰</span>
      </p>

      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="mt-8 flex flex-col sm:flex-row sm:items-center sm:justify-end">
            <Socials />
          </div>
        )
      }
    </section>

    <Hr />

    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured" class="pt-12 pb-6">
            <h2 class="text-2xl font-semibold tracking-wide">置顶文章</h2>
            <ul>
              {featuredPosts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </section>
          {recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">最新文章</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/page/2/">
        全部文章
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexEl = document.querySelector("#main-content");
    if (indexEl instanceof HTMLElement) {
      const indexLayout = indexEl.dataset?.layout;
      if (indexLayout) {
        sessionStorage.setItem("backUrl", "/");
      }
    }
  });
</script>

<script>
  // Fetch a single sentence (一言) from hitokoto with localStorage cache
  document.addEventListener("astro:page-load", async () => {
    const container = document.querySelector('#hitokoto');
    if (!container) return;

    const textWrapper = container.querySelector('.hitokoto-text');
    const innerEl = container.querySelector('.hitokoto-inner');
    const fromEl = container.querySelector('.hitokoto-from');

    const CACHE_KEY = 'hitokoto_cache';
    const CACHE_TIME_KEY = 'hitokoto_cache_time';
    const CACHE_DURATION = 10 * 60 * 1000; // 10 分钟缓存

    // 显示一言内容
    function displayHitokoto(sentence: string, source: string) {
      if (innerEl && innerEl instanceof HTMLElement) {
        innerEl.textContent = sentence;
      }
      if (textWrapper && textWrapper instanceof HTMLElement) {
        textWrapper.classList.remove('fade-in');
        textWrapper.offsetHeight; // trigger reflow
        textWrapper.classList.add('fade-in');
      }
      if (fromEl && fromEl instanceof HTMLElement) {
        fromEl.textContent = source ? ` —— ${source}` : '';
        fromEl.classList.remove('fade-in');
        fromEl.offsetHeight;
        fromEl.classList.add('fade-in');
      }
    }

    // 尝试从缓存加载
    function loadFromCache(): { sentence: string; source: string } | null {
      try {
        const cached = localStorage.getItem(CACHE_KEY);
        const cachedTime = localStorage.getItem(CACHE_TIME_KEY);
        if (cached && cachedTime) {
          const age = Date.now() - parseInt(cachedTime, 10);
          if (age < CACHE_DURATION) {
            return JSON.parse(cached);
          }
        }
      } catch { /* ignore */ }
      return null;
    }

    // 保存到缓存
    function saveToCache(sentence: string, source: string) {
      try {
        localStorage.setItem(CACHE_KEY, JSON.stringify({ sentence, source }));
        localStorage.setItem(CACHE_TIME_KEY, Date.now().toString());
      } catch { /* ignore */ }
    }

    // 先显示缓存内容（如果有）
    const cached = loadFromCache();
    if (cached) {
      displayHitokoto(cached.sentence, cached.source);
    }

    // 后台请求新内容
    try {
      const controller = new AbortController();
      const timeout = setTimeout(() => controller.abort(), 5000);

      const res = await fetch('https://v1.hitokoto.cn/?c=a&c=b&c=d&c=i&c=k', { signal: controller.signal });
      clearTimeout(timeout);

      if (!res.ok) throw new Error('Network response failed.');
      const data = await res.json();

      const sentence = data.hitokoto || data.sentence || '';
      const source = data.from || data.from_who || '';

      // 只有内容不同时才更新显示
      if (!cached || cached.sentence !== sentence) {
        displayHitokoto(sentence, source);
      }
      saveToCache(sentence, source);
    } catch {
      // API 失败时保持当前内容（默认或缓存）
    }
  });
</script>
